# Copy to /etc/vohive-keepalive/service.env, set mode 0600, and replace placeholders.
VOHIVE_BASE_URL=http://127.0.0.1:17575/api
VOHIVE_USER=admin
VOHIVE_PASSWORD=CHANGE_ME

BASIC_USER=admin
BASIC_PASSWORD=CHANGE_ME_TOO
LISTEN_HOST=127.0.0.1
LISTEN_PORT=7582

CONFIG_PATH=/etc/vohive-keepalive/config.json
DATABASE_PATH=/var/lib/vohive-keepalive/keepalive.db

# Optional PushDeer notifications. Leave PUSHDEER_KEY empty to disable delivery.
PUSHDEER_KEY=
PUSHDEER_ENDPOINT=https://api2.pushdeer.com/message/push
